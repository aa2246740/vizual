{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Project Timeline",
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["completed", "in-progress", "pending"]
          },
          "startDate": { "type": "string", "format": "date" },
          "endDate": { "type": "string", "format": "date" }
        },
        "required": ["id", "title", "status"]
      }
    }
  },
  "required": ["nodes"]
}
