{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Code Block",
  "properties": {
    "code": {
      "type": "string",
      "description": "The code string to render"
    },
    "language": {
      "type": "string",
      "enum": ["javascript", "typescript", "python", "go", "rust", "java", "bash", "json", "html", "css", "sql", "other"],
      "default": "javascript"
    },
    "filename": {
      "type": "string"
    },
    "highlightLines": {
      "type": "array",
      "items": { "type": "integer" },
      "description": "Line numbers to highlight"
    }
  },
  "required": ["code"]
}
