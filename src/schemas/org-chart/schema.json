{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Organization Chart",
  "definitions": {
    "person": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "department": { "type": "string" },
        "children": {
          "type": "array",
          "items": { "$ref": "#/definitions/person" }
        }
      },
      "required": ["name"]
    }
  },
  "properties": {
    "root": { "$ref": "#/definitions/person" }
  },
  "required": ["root"]
}
