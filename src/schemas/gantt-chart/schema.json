{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Gantt Chart",
  "properties": {
    "title": { "type": "string" },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "startDate": { "type": "string" },
          "endDate": { "type": "string" },
          "progress": { "type": "integer", "minimum": 0, "maximum": 100 },
          "status": { "type": "string", "enum": ["completed", "in-progress", "pending", "delayed"] },
          "assignee": { "type": "string" }
        },
        "required": ["id", "name", "startDate", "endDate", "status"]
      }
    }
  },
  "required": ["tasks"]
}
