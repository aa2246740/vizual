{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Budget Report",
  "properties": {
    "title": { "type": "string" },
    "period": { "type": "string" },
    "currency": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "category": { "type": "string" },
          "budget": { "type": "number" },
          "actual": { "type": "number" },
          "variance": { "type": "number" }
        },
        "required": ["category", "budget", "actual"]
      }
    }
  },
  "required": ["title", "items"]
}
