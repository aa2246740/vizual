{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Pie / Donut Chart",
  "properties": {
    "title": { "type": "string" },
    "donut": { "type": "boolean", "default": false },
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "value": { "type": "number" }
        },
        "required": ["label", "value"]
      }
    }
  },
  "required": ["segments"]
}
