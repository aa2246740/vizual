{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Audit Log",
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string" },
          "user": { "type": "string" },
          "action": { "type": "string" },
          "resource": { "type": "string" },
          "status": { "type": "string", "enum": ["success", "failure", "warning"] },
          "details": { "type": "string" }
        },
        "required": ["timestamp", "user", "action"]
      }
    }
  },
  "required": ["entries"]
}
