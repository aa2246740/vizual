{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Feature Table",
  "properties": {
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "priority": { "type": "string", "enum": ["high", "medium", "low"] },
          "status": { "type": "string", "enum": ["planned", "in-progress", "completed", "cancelled"] },
          "description": { "type": "string" },
          "assignee": { "type": "string" }
        },
        "required": ["id", "name"]
      }
    }
  },
  "required": ["features"]
}
