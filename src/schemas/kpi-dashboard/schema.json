{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "KPI Dashboard",
  "properties": {
    "title": { "type": "string" },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "value": { "type": "number" },
          "target": { "type": "number" },
          "unit": { "type": "string" },
          "trend": { "type": "string", "enum": ["up", "down", "flat"] }
        },
        "required": ["name", "value"]
      }
    }
  },
  "required": ["title", "metrics"]
}
