{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Kanban Board",
  "properties": {
    "columns": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "cards": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "content": { "type": "string" },
                "labels": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "done": { "type": "boolean" }
              },
              "required": ["id", "content"]
            }
          }
        },
        "required": ["id", "title", "cards"]
      }
    }
  },
  "required": ["columns"]
}
