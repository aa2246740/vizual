        "tags": [
          { "label": "DevOps", "color": "#e67e22" },
          { "label": "P0", "color": "#e74c3c" }
        ],
        "assignee": {
          "name": "王磊",
          "avatar": "王"
        },
        "priority": "high",
        "completedDate": "2026-04-20"
      },
      "children": []
    },
    "done-3": {
      "type": "KanbanCard",
      "props": {
        "title": "UI设计规范制定",
        "description": "输出完整的UI设计规范文档，包含色彩、字体、间距、组件样式等标准",
        "tags": [
          { "label": "设计", "color": "#9b59b6" },
          { "label": "P1", "color": "#e67e22" }
        ],
        "assignee": {
          "name": "李婷",
          "avatar": "李"
        },
        "priority": "medium",
        "completedDate": "2026-04-21"
      },
      "children": []
    },
    "done-4": {
      "type": "KanbanCard",
      "props": {
        "title": "开发环境配置",
        "description": "统一团队开发环境配置，包含ESLint、Prettier、Git Hooks等代码规范工具",
        "tags": [
          { "label": "DevOps", "color": "#e67e22" },
          { "label": "P1", "color": "#e67e22" }
        ],
        "assignee": {
          "name": "赵阳",
          "avatar": "赵"
        },
