{
  "root": "kanban-board",
  "elements": {
    "kanban-board": {
      "type": "KanbanBoard",
      "props": {
        "title": "项目管理看板",
        "style": {
          "padding": "24px",
          "background": "#f5f7fa",
          "minHeight": "100vh"
        }
      },
      "children": ["header", "columns-container"]
    },
    "header": {
      "type": "Flex",
      "props": {
        "justify": "space-between",
        "align": "center",
        "style": {
          "marginBottom": "24px"
        }
      },
      "children": ["title-text", "header-stats"]
    },
    "title-text": {
      "type": "Text",
      "props": {
        "value": "项目管理看板",
        "size": "xl",
        "weight": "bold",
        "color": "#1a1a2e"
      },
      "children": []
    },
    "header-stats": {
      "type": "Flex",
      "props": {
        "gap": "16px",
        "align": "center"
      },
      "children": ["stat-todo", "stat-progress", "stat-done"]
    },
    "stat-todo": {
      "type": "Badge",
      "props": {
        "label": "待办 3",
        "color": "#e67e22",
        "variant": "outline"
      },
      "children": []
    },
    "stat-progress": {
      "type": "Badge",
      "props": {
        "label": "进行中 2",
        "color": "#3498db",
        "variant": "outline"
      },
      "children": []
    },
    "stat-done": {
      "type": "Badge",
      "props": {
        "label": "已完成 4",
        "color": "#27ae60",
        "variant": "outline"
      },
      "children": []
    },
    "columns-container": {
      "type": "Flex",
      "props": {
        "gap": "20px",
        "align": "flex-start",
        "style": {
          "overflowX": "auto"
        }
      },
      "children": ["col-todo", "col-progress", "col-done"]
    },

    "col-todo": {
      "type": "KanbanColumn",
      "props": {
        "title": "待办",
        "count": 3,
        "color": "#e67e22",
        "icon": "clock",
        "style": {
          "minWidth": "320px",
          "flex": 1
        }
      },
      "children": ["todo-1", "todo-2", "todo-3"]
    },
    "todo-1": {
      "type": "KanbanCard",
      "props": {
        "title": "用户权限系统设计",
        "description": "设计基于RBAC的用户权限管理方案，支持多租户场景下的角色分配与资源隔离",
        "tags": [
          { "label": "设计", "color": "#9b59b6" },
          { "label": "P0", "color": "#e74c3c" }
        ],
        "assignee": {
          "name": "张明",
          "avatar": "张"
        },
        "priority": "high",
        "dueDate": "2026-05-05"
      },
      "children": []
    },
    "todo-2": {
      "type": "KanbanCard",
      "props": {
        "title": "API接口文档编写",
        "description": "完成用户模块、订单模块的RESTful API文档，包含请求示例和错误码说明",
        "tags": [
          { "label": "文档", "color": "#3498db" },
          { "label": "P1", "color": "#e67e22" }
        ],
        "assignee": {
          "name": "李婷",
          "avatar": "李"
        },
        "priority": "medium",
        "dueDate": "2026-05-08"
      },
      "children": []
    },
    "todo-3": {
      "type": "KanbanCard",
      "props": {
        "title": "性能监控方案调研",
        "description": "调研前端性能监控方案，对比Sentry、Datadog等工具，输出技术选型报告",
        "tags": [
          { "label": "调研", "color": "#1abc9c" },
          { "label": "P2", "color": "#95a5a6" }
        ],
        "assignee": {
          "name": "王磊",
          "avatar": "王"
        },
        "priority": "low",
        "dueDate": "2026-05-12"
      },
      "children": []
    },

    "col-progress": {
      "type": "KanbanColumn",
      "props": {
        "title": "进行中",
        "count": 2,
        "color": "#3498db",
        "icon": "spinner",
        "style": {
          "minWidth": "320px",
          "flex": 1
        }
      },
      "children": ["progress-1", "progress-2"]
    },
    "progress-1": {
      "type": "KanbanCard",
      "props": {
        "title": "首页重构开发",
        "description": "使用Vue 3 Composition API重构首页，优化加载性能，目标LCP低于2秒",
        "tags": [
          { "label": "开发", "color": "#e67e22" },
          { "label": "P0", "color": "#e74c3c" },
          { "label": "前端", "color": "#3498db" }
        ],
        "assignee": {
          "name": "赵阳",
          "avatar": "赵"
        },
        "priority": "high",
        "dueDate": "2026-05-03",
        "progress": 65
      },
      "children": []
    },
    "progress-2": {
      "type": "KanbanCard",
      "props": {
        "title": "数据库索引优化",
        "description": "分析慢查询日志，为订单表和用户表添加复合索引，目标查询耗时降低50%",
        "tags": [
          { "label": "后端", "color": "#2ecc71" },
          { "label": "P1", "color": "#e67e22" }
        ],
        "assignee": {
          "name": "陈华",
          "avatar": "陈"
        },
        "priority": "medium",
        "dueDate": "2026-05-06",
        "progress": 40
      },
      "children": []
    },

    "col-done": {
      "type": "KanbanColumn",
      "props": {
        "title": "已完成",
        "count": 4,
        "color": "#27ae60",
        "icon": "check-circle",
        "style": {
          "minWidth": "320px",
          "flex": 1
        }
      },
      "children": ["done-1", "done-2", "done-3", "done-4"]
    },
    "done-1": {
      "type": "KanbanCard",
      "props": {
        "title": "项目技术栈选型",
        "description": "完成前后端技术栈选型，确定Vue 3 + Node.js + PostgreSQL技术方案",
        "tags": [
          { "label": "架构", "color": "#9b59b6" },
          { "label": "P0", "color": "#e74c3c" }
        ],
        "assignee": {
