{
  "root": "feedback-form",
  "elements": {
    "feedback-form": {
      "type": "FormBuilder",
      "props": {
        "title": "用户反馈调查",
        "description": "感谢您抽出时间提供反馈，您的意见对我们非常重要。",
        "submitLabel": "提交反馈",
        "layout": "vertical",
        "fields": [
          {
            "id": "name",
            "type": "TextInput",
            "label": "姓名",
            "placeholder": "请输入您的姓名",
            "required": true,
            "validation": {
              "required": true,
              "message": "姓名为必填项"
            }
          },
          {
            "id": "email",
            "type": "TextInput",
            "label": "邮箱",
            "placeholder": "请输入您的邮箱地址",
            "required": true,
            "validation": {
              "required": true,
              "pattern": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$",
              "message": "请输入有效的邮箱地址"
            }
          },
          {
            "id": "satisfaction",
            "type": "Rating",
            "label": "满意度评分",
            "maxRating": 5,
            "defaultValue": 0,
            "allowClear": true,
            "tooltips": ["非常不满意", "不满意", "一般", "满意", "非常满意"]
          },
          {
            "id": "issueType",
            "type": "Select",
            "label": "问题类型",
            "placeholder": "请选择问题类型",
            "options": [
              { "label": "Bug", "value": "bug" },
              { "label": "建议", "value": "suggestion" },
              { "label": "咨询", "value": "inquiry" },
              { "label": "其他", "value": "other" }
            ],
            "required": false
          },
          {
            "id": "description",
            "type": "TextArea",
            "label": "详细描述",
            "placeholder": "请详细描述您的问题或建议...",
            "rows": 6,
            "maxLength": 1000,
            "showCount": true,
            "required": false
          }
        ]
      },
      "children": []
    }
  }
}